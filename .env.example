# Copy this file to .env and fill in your values
# DO NOT commit .env to version control

# HuggingFace token for accessing gated models (e.g., Llama)
HF_TOKEN=your_huggingface_token_here

# Cache directory for models and datasets (default: /tmp/huggingface)
# Use /tmp or a larger volume if your EBS is small
HF_HOME=/tmp/huggingface
